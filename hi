local currentDropdownType = nil
local function CloseDropdown() DropdownContainer.Visible = false; currentDropdownType = nil end

local function OpenDropdown(btnRef, dType)
    if currentDropdownType == dType then CloseDropdown() return end
    for _, child in ipairs(DropdownList:GetChildren()) do if child:IsA("TextButton") then child:Destroy() end end
    
    currentDropdownType = dType
    DropdownContainer.Position = UDim2.new(0, btnRef.AbsolutePosition.X, 0, btnRef.AbsolutePosition.Y + btnRef.AbsoluteSize.Y + 5)
    DropdownContainer.Visible = true

    if dType == "Weapon" then
        local tools = {}
        local backpack = LocalPlayer:FindFirstChild("Backpack")
        local char = LocalPlayer.Character
        local function addToolsFrom(parent)
            if not parent then return end
            for _, v in ipairs(parent:GetChildren()) do
                if v:IsA("Tool") and not tools[v.Name] then
                    tools[v.Name] = true
                    local btn = Instance.new("TextButton", DropdownList)
                    btn.Size = UDim2.new(1, 0, 0, 32)
                    btn.Text = "  " .. v.Name
                    btn.TextXAlignment = Enum.TextXAlignment.Left
                    btn.BackgroundColor3 = Color3.fromRGB(25, 32, 50)
                    btn.TextColor3 = Color3.fromRGB(255, 255, 255) 
                    btn.TextStrokeTransparency = 1
                    btn.Font = Enum.Font.Gotham
                    btn.TextSize = 13
                    btn.ZIndex = 105
                    btn.MouseButton1Click:Connect(function()
                        _G.SelectedWeaponName = v.Name
                        WeaponDropdownBtn.Text = "Weapon: " .. v.Name
                        CloseDropdown()
                    end)
                end
            end
        end
        addToolsFrom(backpack); addToolsFrom(char)
        
    elseif dType == "Mob" then
        for _, data in ipairs(MobsData) do
            local btn = Instance.new("TextButton", DropdownList)
            btn.Size = UDim2.new(1, 0, 0, 32)
            btn.Text = string.format("  [Lv.%d] %s", data.lvl, data.mob)
            btn.TextXAlignment = Enum.TextXAlignment.Left
            btn.BackgroundColor3 = Color3.fromRGB(25, 32, 50)
            btn.TextColor3 = Color3.fromRGB(255, 255, 255)
            btn.TextStrokeTransparency = 1
            btn.Font = Enum.Font.Gotham
            btn.TextSize = 13
            btn.ZIndex = 105
            btn.MouseButton1Click:Connect(function()
                _G.SelectedMobData = data
                MobDropdownBtn.Text = "Target: " .. data.mob
                if _G.AutoChooseMob then 
                    _G.AutoChooseMob = false
                    AutoChooseMobToggle.Text = "☐ Auto Choose Mob: OFF"
                    AutoChooseMobToggle.BackgroundColor3 = Color3.fromRGB(180, 50, 50)
                end
                CloseDropdown()
            end)
        end
    end
    DropdownList.CanvasSize = UDim2.new(0, 0, 0, DropdownLayout.AbsoluteContentSize.Y)
end

-- ==========================================
-- ฟังก์ชันสนับสนุน (MoveTo รุ่นปลอดภัย ไม่ค้างตอนตัวตาย)
-- ==========================================
local function MoveTo(targetCFrame)
    local char = LocalPlayer.Character
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    local humanoid = char and char:FindFirstChildOfClass("Humanoid")
    if not hrp or not humanoid then return end
    
    local distance = (hrp.Position - targetCFrame.Position).Magnitude
    if distance > 10 then
        humanoid.PlatformStand = true
        local tweenInfo = TweenInfo.new(distance / _G.TweenSpeed, Enum.EasingStyle.Linear)
        local tween = TweenService:Create(hrp, tweenInfo, {CFrame = targetCFrame})
        tween:Play()
        
        -- ป้องกันการบัคค้างถ้าตัวละครตายระหว่างบิน
        local tweenTimeout = tick() + (distance / _G.TweenSpeed) + 2
        while tween.PlaybackState == Enum.PlaybackState.Playing do
            task.wait(0.1)
            if tick() > tweenTimeout or not char:FindFirstChild("HumanoidRootPart") or humanoid.Health <= 0 then
                tween:Cancel()
                break
            end
        end
        
        if humanoid then humanoid.PlatformStand = false end
    else
        hrp.CFrame = targetCFrame
    end
end

