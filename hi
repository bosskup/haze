local function GetCurrentLevel()
    local levelFrame = LocalPlayer:WaitForChild("PlayerGui"):FindFirstChild("HUD")
    if not levelFrame then return 1 end
    local lbl = levelFrame.MainFrame.Main.Holder.NumberStats.Level
    for _, child in ipairs(lbl:GetDescendants()) do
        if child:IsA("TextLabel") then
            local lvl = tonumber(string.match(child.Text, "%d+"))
            if lvl then return lvl end
        end
    end
    return 1 
end

local function GetTargetMobData()
    if _G.AutoChooseMob then
        local currentLevel = GetCurrentLevel()
        local bestMob = MobsData[1]
        for _, data in ipairs(MobsData) do
            if currentLevel >= data.lvl then bestMob = data end
        end
        return bestMob
    else
        return _G.SelectedMobData
    end
end

local function GetNearestMob(targetMobName)
    if not npcZonesFolder then return nil end
    local nearestMob, shortestDist = nil, math.huge
    local myPos = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") and LocalPlayer.Character.HumanoidRootPart.Position or Vector3.new(0, 0, 0)
    for _, island in pairs(npcZonesFolder:GetChildren()) do
        for _, folder in pairs(island:GetChildren()) do
            if folder:IsA("Folder") or folder:IsA("Model") then
                for _, mob in pairs(folder:GetChildren()) do
                    if mob:IsA("Model") then
                        local cleanName = string.gsub(mob.Name, "%d+", "")
                        cleanName = string.gsub(cleanName, "^%s*(.-)%s*$", "%1")
                        
                        if string.lower(cleanName) == string.lower(targetMobName) then 
                            local hum = mob:FindFirstChild("Humanoid")
                            local hrp = mob:FindFirstChild("HumanoidRootPart")
                            if hum and hum.Health > 0 and hrp then
                                local dist = (hrp.Position - myPos).Magnitude
                                if dist < shortestDist then
                                    shortestDist = dist
                                    nearestMob = mob
                                end
                            end
                        end
                    end
                end
            end
        end
    end
    return nearestMob
end

